{
  "name": "arschat-ext-hello",
  "version": "1.0.0",
  "description": "ArsChat 拡張機能システムのテスト用拡張",
  "arschat": {
    "displayName": "Hello Extension",
    "description": "ArsChat 拡張機能システムの動作確認用サンプル拡張。AI チャットとシンプルな Hello ページを提供します。",
    "icon": "👋",
    "permissions": ["ai:send", "ai:stream"],
    "main": "main.js",
    "renderer": "dist/renderer.js",
    "pages": [
      {
        "id": "hello",
        "title": "Hello Page",
        "icon": "👋",
        "sidebar": true
      },
      {
        "id": "ai-chat",
        "title": "AI テスト",
        "icon": "🤖",
        "sidebar": true
      }
    ]
  },
  "scripts": {
    "build": "node build.js"
  }
}
